<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="CertForge.Avalonia.Views.ExamSelectorView">

  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Spacing="12" Margin="20">
      <TextBlock Text="Available Exams"
                 FontSize="24"
                 FontWeight="Bold"
                 Foreground="{StaticResource TextPrimaryBrush}" />

      <TextBlock Text="Select a certification exam to begin your study session."
                 FontSize="14"
                 Foreground="{StaticResource TextDimBrush}"
                 TextWrapping="Wrap"
                 Margin="0,0,0,8" />

      <!-- Dynamic exam cards — populated from code-behind -->
      <ItemsControl x:Name="ExamCards"
                     ItemsSource="{Binding}"
                     x:CompileBindings="False">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Background="{StaticResource CardBgBrush}"
                    CornerRadius="10"
                    BorderBrush="{Binding Color, Mode=OneWay, FallbackValue=#00F0FF}"
                    BorderThickness="1"
                    Padding="18,14"
                    Margin="0,0,0,8">
              <Grid ColumnDefinitions="*,Auto">
                <StackPanel Spacing="4">
                  <TextBlock Text="{Binding DisplayName, Mode=OneWay}"
                             FontSize="18"
                             FontWeight="Bold"
                             Foreground="{Binding Color, Mode=OneWay, FallbackValue=#00F0FF}" />
                  <TextBlock Text="{Binding Description, Mode=OneWay}"
                             FontSize="13"
                             Foreground="{StaticResource TextDimBrush}" />
                  <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,6,0,0">
                    <Border Background="{StaticResource DarkPanelBrush}"
                            CornerRadius="4"
                            Padding="8,2">
                      <TextBlock Text="{Binding QuestionCount, Mode=OneWay}"
                                 FontSize="11"
                                 Foreground="{StaticResource TextDimBrush}" />
                    </Border>
                    <Border Background="{StaticResource DarkPanelBrush}"
                            CornerRadius="4"
                            Padding="8,2">
                      <TextBlock Text="{Binding DomainCount, Mode=OneWay}"
                                 FontSize="11"
                                 Foreground="{StaticResource TextDimBrush}" />
                    </Border>
                    <Border Background="{StaticResource DarkPanelBrush}"
                            CornerRadius="4"
                            Padding="8,2">
                      <TextBlock Text="{Binding Level, Mode=OneWay}"
                                 FontSize="11"
                                 Foreground="{StaticResource StatusAmberBrush}" />
                    </Border>
                  </StackPanel>
                </StackPanel>
                <Button Grid.Column="1"
                        Content="Start"
                        Click="OnStartClicked"
                        CornerRadius="8"
                        Padding="20,8"
                        FontWeight="Bold"
                        VerticalAlignment="Center" />
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

    </StackPanel>
  </ScrollViewer>
</UserControl>
